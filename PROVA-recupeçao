        }
        .galeria img {
            width: 45%;
            height: auto;
            border: 3px solid #fff;
            box-shadow: 0 4px 8px rgba(0,0,0,0.2);
        }

     
        .img-float {
            float: left;
            margin-right: 15px;
            margin-bottom: 10px;
            width: 150px;
            height: 150px;
            object-fit: cover;
            border-radius: 50%;
        }

        .limpar { clear: both; } 
    </style>
</head>
